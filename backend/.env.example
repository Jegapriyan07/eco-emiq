# MQTT (disabled - real integration removed from this env example)
MQTT_ENABLED=0

# WiFi status (demo)
MQTT_DEMO_ENABLED=1
MQTT_DEMO_CONNECT_DELAY_MS=0
MQTT_DEMO_ALWAYS_CONNECTED=1
MQTT_DEMO_DEVICE_ID=demo-device-001
MQTT_DEMO_DEVICE_NAME=ECO-EMIQ Demo
MQTT_DEMO_STATUS_TOPIC=ecotronics/status

# WiFi UI behavior (force status without real MQTT)
WIFI_FORCE_CONNECTED=1
WIFI_CONNECTED_MESSAGE=Connected through MQTT

# i18n (Multilingual)
I18N_ENABLED=1
I18N_DEFAULT_LOCALE=en
I18N_FALLBACK_LOCALE=en
I18N_SUPPORTED_LOCALES=en,hi,ta

# USB (Serial)
USB_ENABLED=1
SERIAL_PATH=COM3
SERIAL_BAUD=115200

# Server
PORT=8080

# (Docs) Setup commands - keep out of dotenv parsing
# cd /d c:\Users\hires\ECO-emiq\backend
# npm install
# npm start
