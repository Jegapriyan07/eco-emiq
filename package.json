{
  "name": "ecotronics",
  "version": "0.1.0",
  "description": "Local-first carbon emission monitoring platform",
  "private": true,
  "workspaces": [
    "edge-device",
    "backend/*",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "docker compose up",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:edge": "cd edge-device && npm run dev",
    "test": "npm run test --workspaces",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "build": "npm run build --workspaces",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup": "node scripts/setup.js",
    "demo": "node scripts/demo.js"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.0",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "concurrently": "^8.0.0",
    "eslint": "^8.37.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-react": "^7.32.2",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "lint-staged": "^13.2.0",
    "prettier": "^2.8.7",
    "typescript": "^5.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/ecotronics.git"
  },
  "keywords": [
    "carbon-emissions",
    "iot",
    "sustainability",
    "local-first",
    "edge-computing"
  ],
  "author": "EcoTronics Team",
  "license": "MIT",
  "dependencies": {
    "lucide-react": "^0.569.0",
    "mqtt": "^5.15.0"
  }
}
