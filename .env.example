# ═══════════════════════════════════════════════════════════════
# EcoTronics — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────
# CORE
# ─────────────────────────────────────────
ENVIRONMENT=development        # development | staging | production
SECRET_KEY=change-me-to-a-64-char-random-string
SERVICE_VERSION=1.0.0

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DATABASE_URL=postgresql://ecotronics:password@localhost:5432/ecotronics
# For SQLite (dev only):
# DATABASE_URL=sqlite:///./ecotronics.db

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────
# MQTT BROKER
# ─────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ─────────────────────────────────────────
# EMAIL (SMTP)
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@ecotronics.io
SMTP_PASSWORD=your-app-password-here
SMTP_FROM=EcoTronics Alerts <alerts@ecotronics.io>

# ─────────────────────────────────────────
# STRIPE (Billing)
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...

# ─────────────────────────────────────────
# WHATSAPP ALERTS (Twilio WhatsApp API)
# ─────────────────────────────────────────
# Twilio WhatsApp Configuration (Global WhatsApp delivery)
# Sign up: https://www.twilio.com | Console > Account > API Keys
# WhatsApp Sandbox: Start with sandbox for free trial
# WhatsApp Business API: Production use requires approved business account
TWILIO_ACCOUNT_SID=AC...your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155552671

# ─────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-in-production
LOG_DIR=logs
LOG_LEVEL=INFO

# ─────────────────────────────────────────
# TLS / TRAEFIK
# ─────────────────────────────────────────
ACME_EMAIL=admin@ecotronics.io
DOMAIN=ecotronics.io

# ─────────────────────────────────────────
# SERVICE PORTS
# ─────────────────────────────────────────
BACKEND_PORT=3001
ML_SERVICE_PORT=8000
NOTIFICATION_SERVICE_PORT=8001
HEATMAP_SERVICE_PORT=8002
SAAS_SERVICE_PORT=8003
